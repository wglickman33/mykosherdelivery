# Stripe (Frontend - Publishable Key Only)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Google Places API
VITE_GOOGLE_PLACES_API_KEY=your_google_places_api_key
